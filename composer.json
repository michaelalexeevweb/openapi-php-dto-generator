{
    "name": "michaelalexeevweb/openapi-php-dto-generator",
    "description": "Generate immutable PHP DTO classes from OpenAPI schemas with request and response validation.",
    "type": "library",
    "license": "MIT",
    "keywords": [
        "openapi",
        "php",
        "dto",
        "generator"
    ],
    "authors": [
        {
            "name": "Michael Alexeev",
            "email": "michael.alexeev.web@gmail.com"
        }
    ],
    "autoload": {
        "psr-4": {
            "OpenapiPhpDtoGenerator\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "OpenapiPhpDtoGenerator\\Tests\\": "tests/"
        }
    },
    "require": {
        "php": "^8.4",
        "twig/twig": "^3.0",
        "symfony/console": "^7.4",
        "symfony/http-foundation": "^7.4",
        "symfony/mime": "^7.4",
        "symfony/yaml": "^7.4"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5",
        "phpstan/phpstan": "^2.1",
        "ergebnis/phpstan-rules": "^2.13"
    },
    "bin": [
        "bin/console"
    ],
    "archive": {
        "exclude": [
            "/.idea",
            "/.phpunit.cache",
            "/tests",
            "/OpenApiExamples",
            "/vendor"
        ]
    },
    "scripts": {
        "phpstan": "phpstan analyse --configuration=phpstan.neon.dist --memory-limit=1G"
    },
    "config": {
        "platform": {
            "php": "8.4.17"
        }
    }
}
