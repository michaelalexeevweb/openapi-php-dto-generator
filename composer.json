{
    "name": "michaelalexeevweb/openapi-php-dto-generator",
    "description": "Generate PHP DTOs from OpenAPI and validate incoming HTTP requests against OpenAPI schema.",
    "type": "library",
    "license": "MIT",
    "keywords": [
        "php",
        "openapi",
        "dto",
        "dto-generator",
        "api",
        "validation",
        "request-validation",
        "openapi-validation",
        "serializer",
        "deserialization",
        "symfony",
        "laravel",
        "psr-7",
        "framework-agnostic"
    ],
    "authors": [
        {
            "name": "Michael Alexeev",
            "email": "michael.alexeev.web@gmail.com"
        }
    ],
    "autoload": {
        "psr-4": {
            "OpenapiPhpDtoGenerator\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "OpenapiPhpDtoGenerator\\Tests\\": "tests/"
        }
    },
    "require": {
        "php": "^8.3",
        "twig/twig": "^3.0",
        "symfony/console": "^7.4",
        "symfony/http-foundation": "^7.4",
        "symfony/mime": "^7.4",
        "symfony/yaml": "^7.4"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5",
        "phpstan/phpstan": "^2.1",
        "ergebnis/phpstan-rules": "^2.13",
        "phpstan/phpstan-strict-rules": "^2.0",
        "squizlabs/php_codesniffer": "^4.0",
        "slevomat/coding-standard": "^8.29",
        "friendsofphp/php-cs-fixer": "^3.95",
        "symfony/validator": "^7.4",
        "symfony/serializer": "^7.4",
        "symfony/property-access": "^7.4",
        "phpdocumentor/reflection-docblock": "^5.4",
        "symfony/property-info": "^7.4",
        "nyholm/psr7": "^1.8",
        "symfony/psr-http-message-bridge": "^7.4",
        "illuminate/http": "^11 || ^12",
        "illuminate/routing": "^11 || ^12",
        "kubawerlos/php-cs-fixer-custom-fixers": "^3.37"
    },
    "suggest": {
        "symfony/psr-http-message-bridge": "To deserialize PSR-7 ServerRequest objects via DtoDeserializerPsr7 (non-Symfony stacks: Slim, Mezzio, Laminas, Yii3, …).",
        "symfony/validator": "To use the generated DTOs in Symfony attribute mode (--attributes=symfony).",
        "symfony/serializer": "To (de)serialize Symfony attribute-mode DTOs via the Symfony serializer."
    },
    "bin": [
        "bin/console"
    ],
    "archive": {
        "exclude": [
            "/.idea",
            "/.phpunit.cache",
            "/tests",
            "/OpenApiExamples",
            "/vendor"
        ]
    },
    "scripts": {
        "phpstan": "phpstan analyse --configuration=phpstan.neon.dist --memory-limit=1G",
        "cs": "phpcs",
        "cs-fix": "phpcbf",
        "cs-fixer": "php-cs-fixer fix --dry-run --diff",
        "cs-fixer-fix": "php-cs-fixer fix"
    },
    "config": {
        "platform": {
            "php": "8.3.0"
        },
        "allow-plugins": {
            "dealerdirect/phpcodesniffer-composer-installer": true
        }
    }
}
