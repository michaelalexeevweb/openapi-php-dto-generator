#!/usr/bin/env php
<?php

declare(strict_types=1);

use OpenapiPhpDtoGenerator\Command\EchoYamlPropertiesCommand;
use OpenapiPhpDtoGenerator\Command\GenerateDtoCommand;
use OpenapiPhpDtoGenerator\Service\OpenApiDtoGeneratorService;
use OpenapiPhpDtoGenerator\Service\YamlPhpArrayFormatter;
use Symfony\Component\Console\Application;

require_once __DIR__ . '/../vendor/autoload.php';

$application = new Application('OpenAPI PHP DTO Generator');
$application->add(new EchoYamlPropertiesCommand(new YamlPhpArrayFormatter()));
$application->add(new GenerateDtoCommand(new OpenApiDtoGeneratorService()));
$application->setDefaultCommand('openapi:generate-dto');
$application->run();
