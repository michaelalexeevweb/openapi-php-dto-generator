#!/usr/bin/env php
<?php

declare(strict_types=1);

use OpenapiPhpDtoGenerator\Command\GenerateDtoCommand;
use Symfony\Component\Console\Application;

// Walk up directories until vendor/autoload.php is found.
$dir = __DIR__;
$autoloadLoaded = false;

while ($dir !== dirname($dir)) {
    $autoload = $dir . '/vendor/autoload.php';

    if (file_exists($autoload)) {
        require_once $autoload;
        $autoloadLoaded = true;
        break;
    }

    $dir = dirname($dir);
}

if (!$autoloadLoaded) {
    fwrite(STDERR, "Error: Unable to find Composer autoload file.\n");
    exit(1);
}

$application = new Application('OpenAPI PHP DTO Generator');
$application->addCommand(new GenerateDtoCommand());
$application->setDefaultCommand('openapi:generate-dto');

try {
    $application->run();
} catch (\Exception $e) {
    fwrite(STDERR, 'Error: ' . $e->getMessage() . "\n");
    exit(1);
}
